---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

interface Props {
  title?: string;
}

const { title = 'Pedro Moura — UI/UX & Motion Designer' } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- TODO: favicon placeholder — substituir por um ícone real do Pedro Moura -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;600;700;800&family=Poppins:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Rozha+One&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav />
    <slot />
  </body>
</html>
